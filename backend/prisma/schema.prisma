generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SALES
  FINANCE
  VENDOR
  USER
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DiscountType {
  PERCENTAGE
  FIXED
  SPECIAL
}

enum LeadStatus {
  NEW
  SENT
  FAILED
  CONTACTED
  QUALIFIED
  CONVERTED
  CLOSED
}

enum ComplianceStatus {
  DRAFT      @map("draft")
  SUBMITTED  @map("submitted")
  APPROVED   @map("approved")
  REJECTED   @map("rejected")

  @@map("compliance_status")
}

enum PlatformPolicyType {
  TERMS_TEMPLATE         @map("terms_template")
  CANCELLATION_TEMPLATE  @map("cancellation_template")

  @@map("platform_policy_type")
}

enum VerificationStatus {
  PENDING
  VERIFIED
  EXPIRED
  REJECTED
}

enum VerificationMethod {
  EMAIL
}

enum BillingMode {
  TRIAL
  FREE
  PAY_PER_LEAD
  MONTHLY
  HYBRID
}

enum LeadChargeStatus {
  PENDING
  BILLED
  WAIVED
  REFUNDED
}

enum LeadChargeReason {
  TRIAL
  FREE
  INVALID
  DUPLICATE
  MANUAL
}

enum PaymentMethod {
  MANUAL
  STRIPE
}

enum VendorBillingPlanType {
  PAY_PER_LEAD @map("pay_per_lead")
  SUBSCRIPTION @map("subscription")
}

enum InvoiceStatus {
  DRAFT @map("draft")
  SENT  @map("sent")
  PAID  @map("paid")
  VOID  @map("void")
}

enum InvoiceLineItemType {
  LEADS        @map("leads")
  SUBSCRIPTION @map("subscription")
  ADJUSTMENT   @map("adjustment")
}

enum LeadBillingEventStatus {
  PENDING  @map("pending")
  INVOICED @map("invoiced")
  VOID     @map("void")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String?   @map("password_hash")
  name          String?
  role          UserRole  @default(USER)
  vendorId      String?   @map("vendor_id")
  activeCompanyId String? @map("active_company_id")
  employeeCompanyId    String?   @map("employee_company_id")
  employmentVerifiedAt DateTime? @map("employment_verified_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  vendor              Vendor?
  reviewedRequests    VendorRequest[] @relation("ReviewedBy")
  reviewedCompanyRequests CompanyRequest[] @relation("ReviewedCompanyRequests")
  employeeCompany      Company?              @relation("EmployeeCompany", fields: [employeeCompanyId], references: [id])
  activeCompany        Company?              @relation("ActiveCompany", fields: [activeCompanyId], references: [id])
  employeeVerifications EmployeeVerification[]
  companyVerifications UserCompanyVerification[]
  offerClaims          OfferClaim[]
  leads                Lead[]                    @relation("UserLeads")
  redemptions          Redemption[]
  offerClicks          OfferClick[]

  @@map("users")
}

model Vendor {
  id            String       @id @default(uuid())
  userId        String       @unique @map("user_id")
  companyName   String       @map("company_name")
  contactName   String       @map("contact_name")
  email         String
  businessEmail String?      @map("business_email")
  phone         String?
  website       String?
  city          String?
  notes         String?
  logo          String?
  description   String?
  businessType  String?      @map("business_type")
  status        VendorStatus @default(PENDING)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  offers        Offer[]
  requests      VendorRequest[]
  billing       VendorBilling?
  billingPlans  VendorBillingPlan[]
  invoices      Invoice[]
  leadCharges   LeadCharge[]
  leadBillingEvents LeadBillingEvent[]
  leads         Lead[]         @relation("VendorLeads")

  @@map("vendors")
}

model VendorRequest {
  id              String        @id @default(uuid())
  vendorId        String        @map("vendor_id")
  businessType    String?       @map("business_type")
  description     String?
  additionalInfo  String?       @map("additional_info")
  status          RequestStatus @default(PENDING)
  reviewedById    String?       @map("reviewed_by_id")
  reviewedAt      DateTime?     @map("reviewed_at")
  reviewNotes     String?       @map("review_notes")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  vendor          Vendor        @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  reviewedBy      User?         @relation("ReviewedBy", fields: [reviewedById], references: [id])

  @@map("vendor_requests")
}

model Company {
  id            String    @id @default(uuid())
  name          String
  slug          String    @unique
  domain        String?
  allowedDomains String[] @default([]) @map("allowed_domains")
  logo          String?
  employeeCount String?   @map("employee_count")
  headquarters  String?
  description   String?
  verified      Boolean   @default(false)
  bannerImage   String?   @map("banner_image")
  brandColor    String?   @map("brand_color")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  hrContacts    HRContact[]
  offers        Offer[]
  leads         Lead[]
  employees     User[]                @relation("EmployeeCompany")
  activeUsers   User[]                @relation("ActiveCompany")
  employeeVerifications EmployeeVerification[]
  userVerifications     UserCompanyVerification[]
  redemptions           Redemption[]
  offerClicks           OfferClick[]

  @@map("companies")
}

model CompanyRequest {
  id            String        @id @default(uuid())
  companyName   String        @map("company_name")
  requesterName String        @map("requester_name")
  workEmail     String        @map("work_email")
  city          String?
  note          String?
  status        RequestStatus @default(PENDING)
  reviewedById  String?       @map("reviewed_by_id")
  reviewedAt    DateTime?     @map("reviewed_at")
  reviewNotes   String?       @map("review_notes")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  reviewedBy    User?         @relation("ReviewedCompanyRequests", fields: [reviewedById], references: [id])

  @@index([status, createdAt])
  @@index([workEmail])
  @@map("company_requests")
}

model ContactMessage {
  id          String   @id @default(uuid())
  name        String
  email       String
  company     String?
  message     String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@map("contact_messages")
}

model HRContact {
  id          String    @id @default(uuid())
  companyId   String    @map("company_id")
  name        String
  email       String
  phone       String?
  title       String?
  isPrimary   Boolean   @default(false) @map("is_primary")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("hr_contacts")
}

model EmployeeVerification {
  id            String             @id @default(uuid())
  userId        String?            @map("user_id")
  companyId     String             @map("company_id")
  email         String
  status        VerificationStatus @default(PENDING)
  method        VerificationMethod @default(EMAIL)
  codeHash      String             @map("code_hash")
  codeExpiresAt DateTime           @map("code_expires_at")
  attempts      Int                @default(0)
  verifiedAt    DateTime?          @map("verified_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  user          User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  company       Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("employee_verifications")
}

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  icon        String?
  description String?
  color       String?
  bgColor     String?   @map("bg_color")
  image       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  offers      Offer[]

  @@map("categories")
}

model Offer {
  id              String       @id @default(uuid())
  vendorId        String       @map("vendor_id")
  companyId       String       @map("company_id")
  categoryId      String       @map("category_id")
  offerType       String       @default("lead") @map("offer_type")
  configJson      Json?        @map("config_json")
  productName     String?      @map("product_name")
  productModel    String?      @map("product_model")
  productUrl      String?      @map("product_url")
  title           String
  description     String?
  discountValue   String       @map("discount_value")
  discountType    DiscountType @default(PERCENTAGE) @map("discount_type")
  originalPrice   String?      @map("original_price")
  discountedPrice String?      @map("discounted_price")
  terms           Json?        @default("[]")
  howToClaim      Json?        @default("[]") @map("how_to_claim")
  expiryDate      DateTime?    @map("expiry_date")
  featured        Boolean      @default(false)
  verified        Boolean      @default(false)
  active          Boolean      @default(true)
  location        String?
  image           String?
  rating          Float        @default(0)
  reviewCount     Int          @default(0) @map("review_count")
  leadCount       Int          @default(0) @map("lead_count")
  termsText       String       @default("") @map("terms_text")
  cancellationPolicyText String @default("") @map("cancellation_policy_text")
  redemptionInstructionsText String? @map("redemption_instructions_text")
  restrictionsText String?     @map("restrictions_text")
  usePlatformDefaultTerms Boolean @default(true) @map("use_platform_default_terms")
  usePlatformDefaultCancellationPolicy Boolean @default(true) @map("use_platform_default_cancellation_policy")
  vendorAttestationAcceptedAt DateTime? @map("vendor_attestation_accepted_at")
  vendorAttestationAcceptedIp String? @map("vendor_attestation_accepted_ip")
  complianceStatus ComplianceStatus @default(DRAFT) @map("compliance_status")
  complianceNotes String?      @map("compliance_notes")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  vendor          Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category        Category     @relation(fields: [categoryId], references: [id])
  leads           Lead[]
  claims          OfferClaim[]
  redemptions     Redemption[]
  offerClicks     OfferClick[]

  @@map("offers")
}

model PlatformPolicy {
  id          String             @id @default(uuid())
  policyType  PlatformPolicyType @map("policy_type")
  title       String
  bodyText    String             @map("body_text")
  isDefault   Boolean            @default(false) @map("is_default")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  @@index([policyType, isDefault])
  @@map("platform_policies")
}

model Lead {
  id          String     @id @default(uuid())
  userId      String?    @map("user_id")
  offerId     String     @map("offer_id")
  companyId   String     @map("company_id")
  vendorId    String?    @map("vendor_id")
  payloadJson Json?      @map("payload_json")
  consent     Boolean    @default(false)
  consentAt   DateTime?  @map("consent_at")
  consentIp   String?    @map("consent_ip")
  firstName   String     @map("first_name")
  lastName    String     @map("last_name")
  email       String
  vendorNotificationEmail String? @map("vendor_notification_email")
  phone       String?
  employeeId  String?    @map("employee_id")
  message     String?
  status      LeadStatus @default(NEW)
  vendorNotes String?    @map("vendor_notes")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  user        User?      @relation("UserLeads", fields: [userId], references: [id], onDelete: SetNull)
  offer       Offer      @relation(fields: [offerId], references: [id], onDelete: Cascade)
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendor      Vendor?    @relation("VendorLeads", fields: [vendorId], references: [id], onDelete: SetNull)
  leadCharge  LeadCharge?
  billingEvent LeadBillingEvent?

  @@map("leads")
}

model VendorBillingPlan {
  id                   String                @id @default(uuid())
  vendorId             String                @map("vendor_id")
  planType             VendorBillingPlanType @map("plan_type")
  pricePerLead         Decimal?              @db.Decimal(10, 2) @map("price_per_lead")
  monthlyFee           Decimal?              @db.Decimal(10, 2) @map("monthly_fee")
  includedLeadsPerMonth Int?                 @map("included_leads_per_month")
  overagePricePerLead  Decimal?              @db.Decimal(10, 2) @map("overage_price_per_lead")
  billingCycleDay      Int                   @default(1) @map("billing_cycle_day")
  currency             String                @default("CAD")
  isActive             Boolean               @default(true) @map("is_active")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")

  vendor               Vendor                @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, isActive])
  @@map("vendor_billing_plans")
}

model Invoice {
  id          String     @id @default(uuid())
  vendorId    String     @map("vendor_id")
  periodStart DateTime   @db.Date @map("period_start")
  periodEnd   DateTime   @db.Date @map("period_end")
  status      InvoiceStatus @default(DRAFT)
  subtotal    Decimal    @db.Decimal(12, 2)
  tax         Decimal    @db.Decimal(12, 2)
  total       Decimal    @db.Decimal(12, 2)
  notes       String?
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  vendor            Vendor              @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  lineItems         InvoiceLineItem[]
  leadBillingEvents LeadBillingEvent[]

  @@unique([vendorId, periodStart, periodEnd], map: "invoices_vendor_period_key")
  @@index([vendorId, status])
  @@map("invoices")
}

model InvoiceLineItem {
  id           String              @id @default(uuid())
  invoiceId    String              @map("invoice_id")
  itemType     InvoiceLineItemType @map("item_type")
  description  String
  quantity     Int
  unitPrice    Decimal             @db.Decimal(12, 2) @map("unit_price")
  amount       Decimal             @db.Decimal(12, 2)
  metadataJson Json?               @map("metadata_json")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  invoice      Invoice             @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_line_items")
}

model LeadBillingEvent {
  id            String                 @id @default(uuid())
  leadId        String                 @unique @map("lead_id")
  vendorId      String                 @map("vendor_id")
  billedAt      DateTime               @default(now()) @map("billed_at")
  invoiceId     String?                @map("invoice_id")
  billingStatus LeadBillingEventStatus @default(PENDING) @map("billing_status")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")

  lead          Lead                   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  vendor        Vendor                 @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  invoice       Invoice?               @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([vendorId, billingStatus])
  @@index([invoiceId])
  @@map("lead_billing_events")
}

model VendorBilling {
  id              String       @id @default(uuid())
  vendorId        String       @unique @map("vendor_id")
  billingMode     BillingMode  @default(TRIAL) @map("billing_mode")
  postTrialMode   BillingMode? @map("post_trial_mode")
  trialEndsAt     DateTime?    @map("trial_ends_at")
  leadPriceCents  Int          @default(0) @map("lead_price_cents")
  monthlyFeeCents Int          @default(0) @map("monthly_fee_cents")
  paymentMethod   PaymentMethod @default(MANUAL) @map("payment_method")
  stripeCustomerId String?      @map("stripe_customer_id")
  stripeSubscriptionId String?  @map("stripe_subscription_id")
  currency        String       @default("USD")
  billingDay      Int          @default(1) @map("billing_day")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  vendor      Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("vendor_billing")
}

model LeadCharge {
  id           String            @id @default(uuid())
  leadId       String            @unique @map("lead_id")
  vendorId     String            @map("vendor_id")
  amountCents  Int               @default(0) @map("amount_cents")
  currency     String            @default("USD")
  status       LeadChargeStatus  @default(PENDING)
  reason       LeadChargeReason?
  chargeableAt DateTime          @default(now()) @map("chargeable_at")
  billedAt     DateTime?         @map("billed_at")
  notes        String?
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, chargeableAt])
  @@map("lead_charges")
}

model UserCompanyVerification {
  id                 String   @id @default(uuid())
  userId             String   @map("user_id")
  companyId          String   @map("company_id")
  verificationMethod String   @default("work_email") @map("verification_method")
  verifiedAt         DateTime @map("verified_at")
  expiresAt          DateTime @map("expires_at")
  status             String   @default("verified")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId, status, expiresAt])
  @@index([companyId, status])
  @@map("user_company_verifications")
}

model OfferClaim {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  offerId   String   @map("offer_id")
  claimedAt DateTime @default(now()) @map("claimed_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  offer     Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([userId, offerId])
  @@index([offerId])
  @@map("offer_claims")
}

model Redemption {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  offerId    String    @map("offer_id")
  companyId  String    @map("company_id")
  code       String
  redeemedAt DateTime? @map("redeemed_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  offer      Offer     @relation(fields: [offerId], references: [id], onDelete: Cascade)
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, offerId])
  @@index([offerId])
  @@index([companyId])
  @@map("redemptions")
}

model OfferClick {
  id        String    @id @default(uuid())
  userId    String?   @map("user_id")
  offerId   String    @map("offer_id")
  companyId String    @map("company_id")
  clickedAt DateTime  @default(now()) @map("clicked_at")
  referrer  String?
  userAgent String?   @map("user_agent")
  createdAt DateTime  @default(now()) @map("created_at")

  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  offer     Offer     @relation(fields: [offerId], references: [id], onDelete: Cascade)
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([offerId, clickedAt])
  @@index([companyId, clickedAt])
  @@index([userId, clickedAt])
  @@map("offer_clicks")
}
