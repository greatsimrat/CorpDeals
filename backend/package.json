{
  "name": "corpdeals-backend",
  "version": "1.0.0",
  "description": "CorpDeals Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "prisma generate && tsx watch src/index.ts",
    "build": "tsc",
    "routes:audit": "tsx src/scripts/route-audit.ts",
    "routes:test": "powershell -ExecutionPolicy Bypass -File scripts/test-routes.ps1",
    "prestart": "prisma generate",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:uat": "tsx prisma/seed-uat.ts",
    "db:categories:audit": "tsx prisma/category-taxonomy-audit.ts",
    "db:billing:backfill": "tsx src/scripts/backfill-vendor-billing-associations.ts",
    "db:rbac:backfill": "tsx src/scripts/backfill-user-role-assignments.ts",
    "db:billing:audit-offers": "tsx src/scripts/audit-offer-billing-compliance.ts",
    "db:billing:revalidate-live-offers": "tsx src/scripts/revalidate-live-offers-billing.ts",
    "db:offers:sync-state": "tsx src/scripts/sync-offer-state-live-status.ts",
    "test:billing": "tsx --test src/lib/vendor-billing-access.test.ts src/lib/vendor-offer-enforcement.test.ts src/lib/offer-counting.test.ts src/lib/billing-preview.test.ts src/lib/lead-dedup.test.ts src/lib/vendor-subscription-plan.test.ts",
    "test:categories": "tsx --test src/lib/category-management.test.ts src/middleware/auth-role-guards.test.ts",
    "db:prepare:uat": "bash scripts/prepare-uat-demo.sh",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@sendgrid/mail": "^8.1.5",
    "@types/nodemailer": "^7.0.10",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.1",
    "stripe": "^17.7.0",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.29",
    "prisma": "^6.19.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
