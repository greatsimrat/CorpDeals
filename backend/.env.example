# Copy this file to `.env.local` for local development only.
# For production, create `.env.prod` on the server instead.

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/corpdeals?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development
APP_ENV=local
VENDOR_NOTIFICATION_TEST_EMAIL=vendor-test@corpdeals.ca
USER_CONFIRMATION_TEST_EMAIL=user-test@corpdeals.ca

# Frontend URL(s) for CORS. In production, set your deployed frontend origin in `.env.prod`.
# You can provide a single origin in FRONTEND_URL or a comma-separated list in FRONTEND_URLS.
FRONTEND_URL="http://localhost:5173"
FRONTEND_URLS=""

# SMTP (Email)
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=your-email@yourdomain.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=support@corpdeals.ca
SUPPORT_EMAIL=support@corpdeals.ca
MAIL_FROM_NAME="CorpDeals"
