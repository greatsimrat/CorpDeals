# Production-only backend environment.
# Copy this file to `.env.prod` on the server.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/corpdeals?schema=public"

JWT_SECRET="replace-this-in-production"
JWT_EXPIRES_IN="7d"

PORT=3001
NODE_ENV=production
APP_ENV=production

FRONTEND_URLS="https://corpdeals.ca,https://www.corpdeals.ca"

MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=your-email@yourdomain.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=support@corpdeals.ca
SUPPORT_EMAIL=support@corpdeals.ca
MAIL_FROM_NAME="CorpDeals"
