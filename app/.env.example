# Copy this file to `.env.local` on your machine.
# This repo should use `.env.local` for machine-specific frontend config.
# In local Vite dev mode, the app falls back to `http://localhost:3001/api` if this is unset.
# In production builds, the app falls back to `https://api.corpdeals.ca/api` if this is unset.
VITE_API_URL=http://localhost:3001/api
